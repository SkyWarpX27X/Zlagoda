@using DTOModels

<div class="card mb-3 shadow-sm border-primary">
    <div class="card-body">
        <h5 class="card-title mb-3">@(IsNew ? "Створення товару в магазині" : "Редагування товару в магазині")</h5>
        
        <div class="mb-3">
            <label class="form-label">UPC</label>
            <input class="form-control" @bind="Product.Upc" disabled="@(!IsNew)" />
        </div>
        
        @if (IsNew)
        {
            <div class="mb-3">
                <label class="form-label">Товар</label>
                <select class="form-select" @bind="Product.ProductId">
                    <option value="0">Оберіть товар</option>
                    @foreach (var p in AvailableProducts)
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>
        }
        else
        {
            <div class="mb-3">
                <label class="form-label">Товар</label>
                <input class="form-control" value="@CurrentProductName" disabled />
            </div>
        }
        
        <div class="mb-3">
            <label class="form-label">Ціна</label>
            <input type="number" step="0.01" class="form-control" @bind="Product.Price" />
        </div>
        
        <div class="mb-3">
            <label class="form-label">Кількість</label>
            <input type="number" class="form-control" @bind="Product.Quantity" />
        </div>
        
        <div class="d-flex justify-content-end gap-2">
            <button class="btn btn-success btn-sm" @onclick="Save">Зберегти</button>
            <button class="btn btn-secondary btn-sm" @onclick="Cancel">Скасувати</button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public StoreProductModifyDTO Product { get; set; } = null!;
    
    [Parameter]
    public bool IsNew { get; set; }

    [Parameter]
    public string CurrentProductName { get; set; } = "";

    [Parameter]
    public IEnumerable<ProductDTO> AvailableProducts { get; set; } = Enumerable.Empty<ProductDTO>();

    [Parameter]
    public EventCallback<StoreProductModifyDTO> OnSave { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private async Task Save()
    {
        await OnSave.InvokeAsync(Product);
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }
}
