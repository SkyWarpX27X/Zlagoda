@using DTOModels
@using Microsoft.AspNetCore.Components.Authorization
<div class="card mb-4 shadow-sm">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Чек #@Receipt.Id</h5>
        <span class="text-muted">@Receipt.PrintDate.ToString("g")</span>
    </div>
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-sm-6">
                <strong>Касир:</strong> @Receipt.EmployeeName<br />
                <strong>Клієнт:</strong> @(string.IsNullOrEmpty(Receipt.CustomerName) ? "Невідомо (не має картки)" : Receipt.CustomerName)
            </div>
            <div class="col-sm-6 text-sm-end">
                <h5 class="text-success mb-1">Всього: @Receipt.TotalSum.ToString("C2")</h5>
                <small class="text-muted">ПДВ: @Receipt.Tax.ToString("C2")</small>
            </div>
        </div>
        <h6 class="mt-3 border-bottom pb-2">Товари в чеку:</h6>
        <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
                <thead>
                <tr>
                    <th>Товар</th>
                    <th class="text-end">Ціна</th>
                    <th class="text-center">К-сть</th>
                    <th class="text-end">Сума</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var sale in Receipt.Sales)
                {
                    <tr>
                        <td>@sale.ProductName</td>
                        <td class="text-end">@sale.Price.ToString("C2")</td>
                        <td class="text-center">@sale.Quantity</td>
                        <td class="text-end fw-bold">@sale.Sum.ToString("C2")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <AuthorizeView Roles="Менеджер">
            <Authorized>
                <div class="d-flex justify-content-end mt-3">
                    <button class="btn btn-danger btn-sm" @onclick="DeleteReceipt">Видалити чек</button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</div>
@code {
    [Parameter] 
    public ReceiptDTO Receipt { get; set; } = null!;

    [Parameter]
    public EventCallback<long> OnDelete { get; set; }

    private void DeleteReceipt()
    {
        OnDelete.InvokeAsync(Receipt.Id);
    }
}
