@page "/products"
@using DTOModels
@using Zlagoda.ViewModels
@inject ProductsVM ViewModel

<h3>Товари</h3>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <button class="btn btn-success" @onclick="CreateProduct">Створити товар</button>
    
    <div class="d-flex align-items-center">
        <label for="categoryFilter" class="me-2 fw-bold">Категорія:</label>
        <select id="categoryFilter" class="form-select" style="width: auto;" @bind="SelectedCategory" @bind:after="StateHasChanged">
            <option value="">Всі категорії</option>
            @foreach (var category in Categories)
            {
                <option value="@category">@category</option>
            }
        </select>
    </div>
</div>

@if (ViewModel.Products == null || !ViewModel.Products.Any())
{
    <p><em>Завантаження...</em></p>
}
else
{
    <div class="product-list" style="max-height: 70vh; overflow-y: auto; padding-right: 10px;">
        @foreach (var product in FilteredProducts)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title mb-0">@product.Name</h5>
                        <span class="badge bg-secondary">@product.Category</span>
                    </div>
                    <h6 class="card-subtitle mb-2 text-muted">Виробник: @product.Manufacturer</h6>
                    <p class="card-text">
                        <strong>Характеристики:</strong> @product.Characteristics<br />
                        <strong>ID:</strong> @product.Id
                    </p>
                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="() => EditProduct(product.Id)">Редагувати</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteProduct(product.Id)">Видалити</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private string SelectedCategory { get; set; } = "";

    private IEnumerable<string> Categories => 
        ViewModel.Products?.Select(p => p.Category).Distinct().OrderBy(c => c) ?? Enumerable.Empty<string>();

    private IEnumerable<ProductDto> FilteredProducts => 
        string.IsNullOrEmpty(SelectedCategory) 
            ? ViewModel.Products 
            : ViewModel.Products.Where(p => p.Category == SelectedCategory);

    protected override void OnInitialized()
    {
        ViewModel.LoadProducts();
    }

    private void CreateProduct()
    {
