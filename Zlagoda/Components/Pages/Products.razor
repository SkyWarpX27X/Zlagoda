@page "/products"
@rendermode InteractiveServer
@using DTOModels
@using Zlagoda.ViewModels
@using Zlagoda.Components.ItemViews
@using Zlagoda.Components.ItemModifies
@inject ProductsVM ViewModel

<h3>Товари</h3>

<div class="mb-3 d-flex justify-content-between align-items-center">
    @if (ViewModel.IsCreating)
    {
        <div class="w-100 me-3">
            <ProductModify Product="@ViewModel.NewProduct" Categories="@Categories" OnSave="@ViewModel.SaveNewProduct" OnCancel="@ViewModel.CancelCreate" />
        </div>
    }
    else
    {
        <button class="btn btn-success" @onclick="ViewModel.ShowCreateNew">Створити товар</button>
    }
    
    <div class="d-flex align-items-center">
        <label for="categoryFilter" class="me-2 fw-bold">Категорія:</label>
        <select id="categoryFilter" class="form-select" style="width: auto;" @bind="SelectedCategory" @bind:after="StateHasChanged">
            <option value="">Всі категорії</option>
            @foreach (var category in Categories)
            {
                <option value="@category">@category</option>
            }
        </select>
    </div>
</div>

@if (ViewModel.Products == null || !ViewModel.Products.Any())
{
    <p><em>Завантаження...</em></p>
}
else
{
    <div class="product-list" style="max-height: 70vh; overflow-y: auto; padding-right: 10px;">
        @foreach (var product in FilteredProducts)
        {
            <ProductView Product="@product" Categories="@Categories" OnSave="ViewModel.EditProduct" OnDelete="ViewModel.DeleteProduct"/>
        }
    </div>
}

@code {
    private string SelectedCategory { get; set; } = "";

    private IEnumerable<string> Categories => 
        ViewModel.Products?.Select(p => p.Category).Distinct().OrderBy(c => c) ?? Enumerable.Empty<string>();

    private IEnumerable<ProductDTO> FilteredProducts => 
        string.IsNullOrEmpty(SelectedCategory) 
            ? ViewModel.Products 
            : ViewModel.Products.Where(p => p.Category == SelectedCategory);

    protected override void OnInitialized()
    {
        ViewModel.LoadProducts();
    }
}
