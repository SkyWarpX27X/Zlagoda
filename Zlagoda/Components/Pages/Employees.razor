@page "/employees"
@rendermode InteractiveServer
@using DTOModels
@using Zlagoda.ViewModels
@using Zlagoda.Components.ItemViews
@using Zlagoda.Components.ItemModifies
@inject EmployeesVM ViewModel

<h3>Працівники</h3>

<div class="mb-3 d-flex justify-content-between align-items-center">
    @if (ViewModel.IsCreating && ViewModel.NewEmployee != null)
    {
        <div class="w-100 me-3">
            <EmployeeModify Employee="@ViewModel.NewEmployee" IsNew="true" OnSave="@ViewModel.SaveNewEmployee" OnCancel="@ViewModel.CancelCreate" />
        </div>
    }
    else
    {
        <button class="btn btn-success" @onclick="ViewModel.ShowCreateNew">Додати працівника</button>
    }
    
    <div class="d-flex align-items-center">
        <label for="roleFilter" class="me-2 fw-bold">Фільтр:</label>
        <select id="roleFilter" class="form-select" style="width: auto;" @bind="RoleFilter" @bind:after="StateHasChanged">
            <option value="All">Всі працівники</option>
            <option value="Cashier">Тільки касири</option>
        </select>
    </div>
</div>

@if (ViewModel.Employees == null || !ViewModel.Employees.Any())
{
    <p><em>Завантаження...</em></p>
}
else
{
    <div class="employee-list" style="max-height: 70vh; overflow-y: auto; padding-right: 10px;">
        @foreach (var employee in FilteredEmployees)
        {
            <EmployeeView Employee="@employee" OnSave="ViewModel.EditEmployee" OnDelete="ViewModel.DeleteEmployee"/>
        }
    </div>
}

@code {
    private string RoleFilter { get; set; } = "All";
    //TODO move to VM and replace with service method
    private IEnumerable<EmployeeDTO> FilteredEmployees => 
        RoleFilter == "Cashier" 
            ? ViewModel.Employees.Where(e => string.Equals(e.Role, "Касир", StringComparison.OrdinalIgnoreCase))
            : ViewModel.Employees;

    protected override void OnInitialized()
    {
        ViewModel.LoadEmployees();
    }
}
