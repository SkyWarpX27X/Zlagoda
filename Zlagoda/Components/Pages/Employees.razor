@page "/employees"
@rendermode InteractiveServer
@using DTOModels
@using Zlagoda.ViewModels
@using Zlagoda.Components.ItemViews
@using Zlagoda.Components.ItemModifies
@inject EmployeesVM ViewModel

<h3>Працівники</h3>

<div class="mb-3">
    @if (ViewModel.IsCreating && ViewModel.NewEmployee != null)
    {
        <div class="w-100 mb-3">
            <EmployeeModify Employee="@ViewModel.NewEmployee" IsNew="true" OnSave="@ViewModel.SaveNewEmployee" OnCancel="@ViewModel.CancelCreate" />
        </div>
    }
    else
    {
        <button class="btn btn-success mb-3" @onclick="ViewModel.ShowCreateNew">Додати працівника</button>
    }
    
    <div class="card bg-light p-3">
        <div class="row g-3 align-items-center">
            <div class="col-md-6">
                <label for="searchSurname" class="form-label fw-bold">Пошук за прізвищем:</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="searchSurname" class="form-control" placeholder="Введіть прізвище..." @bind="SearchSurname" @bind:event="oninput" />
                </div>
            </div>
            
            <div class="col-md-6">
                <label for="roleFilter" class="form-label fw-bold">Фільтр:</label>
                <select id="roleFilter" class="form-select" @bind="RoleFilter">
                    <option value="All">Всі працівники</option>
                    <option value="Cashier">Тільки касири</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (ViewModel.Employees == null || !ViewModel.Employees.Any())
{
    <p><em>Завантаження...</em></p>
}
else
{
    <div class="employee-list" style="max-height: 70vh; overflow-y: auto; padding-right: 10px;">
        @foreach (var employee in FilteredEmployees)
        {
            <EmployeeView Employee="@employee" OnSave="ViewModel.EditEmployee" OnDelete="ViewModel.DeleteEmployee"/>
        }
        
        @if (!FilteredEmployees.Any())
        {
            <div class="alert alert-info mt-2">Не знайдено працівників за вказаними критеріями.</div>
        }
    </div>
}

@code {
    private string SearchSurname { get; set; } = "";
    private string RoleFilter { get; set; } = "All";

    //TODO move to VM and replace with service method
    private IEnumerable<EmployeeDTO> FilteredEmployees
    {
        get
        {
            var query = ViewModel.Employees.AsQueryable();

            if (!string.IsNullOrWhiteSpace(SearchSurname))
            {
                // Assuming FullName is "LastName FirstName Patronymic"
                query = query.Where(e => e.FullName.StartsWith(SearchSurname, StringComparison.OrdinalIgnoreCase));
            }

            if (RoleFilter == "Cashier")
            {
                query = query.Where(e => string.Equals(e.Role, "Касир", StringComparison.OrdinalIgnoreCase));
            }

            return query;
        }
    }

    protected override void OnInitialized()
    {
        ViewModel.LoadEmployees();
    }
}
