@page "/employees"
@using DTOModels
@using Zlagoda.ViewModels
@inject EmployeesVM ViewModel

<h3>Працівники</h3>

<div class="mb-3">
    <button class="btn btn-success" @onclick="CreateEmployee">Додати працівника</button>
</div>

@if (ViewModel.Employees == null || !ViewModel.Employees.Any())
{
    <p><em>Завантаження...</em></p>
}
else
{
    <div class="employee-list" style="max-height: 70vh; overflow-y: auto; padding-right: 10px;">
        @foreach (var employee in ViewModel.Employees)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="card-title mb-0">@employee.FullName</h5>
                        <span class="badge bg-primary">@employee.Role</span>
                    </div>
                    <h6 class="card-subtitle mb-2 text-muted">ID: @employee.Id</h6>
                    <p class="card-text">
                        <strong>Телефон:</strong> @employee.Phone<br />
                        <strong>Адреса:</strong> @employee.Address<br />
                        <strong>Зарплата:</strong> @employee.Salary ₴<br />
                        <strong>Дата народження:</strong> @employee.BirthDate.ToString("d")<br />
                        <strong>Дата прийому на роботу:</strong> @employee.HireDate.ToString("d")
                    </p>
                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-primary btn-sm" @onclick="() => EditEmployee(employee.Id)">Редагувати</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteEmployee(employee.Id)">Видалити</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

