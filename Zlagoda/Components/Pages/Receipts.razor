@page "/receipts"
@rendermode InteractiveServer
@using Zlagoda.ViewModels
@using Zlagoda.Components.ItemViews
@using Zlagoda.Components.ItemModifies
@inject ReceiptsVM ViewModel

<h3>Чеки</h3>

<div class="mb-3">
    @if (ViewModel.IsCreating && ViewModel.NewReceipt != null)
    {
        <div class="w-100 mb-4">
            <ReceiptModify Receipt="@ViewModel.NewReceipt" Customers="@ViewModel.Customers" StoreProducts="@ViewModel.StoreProducts" OnSave="@ViewModel.SaveNewReceipt" OnCancel="@ViewModel.CancelCreate" />
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-3">
            <button class="btn btn-success" @onclick="ViewModel.ShowCreateNew">Створити чек</button>
            
            <div class="d-flex align-items-end gap-3 flex-wrap">
                <div>
                    <label for="employeeFilter" class="form-label fw-bold mb-1">Касир:</label>
                    <select id="employeeFilter" class="form-select" @bind="ViewModel.SelectedEmployee" @bind:after="StateHasChanged">
                        <option value="">Всі касири</option>
                        @foreach (var emp in ViewModel.Employees)
                        {
                            <option value="@emp">@emp</option>
                        }
                    </select>
                </div>
                
                <div>
                    <label for="fromDate" class="form-label fw-bold mb-1">З дати:</label>
                    <input type="date" id="fromDate" class="form-control" @bind="ViewModel.FromDate" @bind:after="StateHasChanged" />
                </div>
                
                <div>
                    <label for="toDate" class="form-label fw-bold mb-1">По дату:</label>
                    <input type="date" id="toDate" class="form-control" @bind="ViewModel.ToDate" @bind:after="StateHasChanged" />
                </div>
                
                <div>
                    <button class="btn btn-outline-secondary" @onclick="ClearFilters">Очистити фільтри</button>
                </div>
            </div>
        </div>
        
        <div class="alert alert-success d-flex justify-content-between align-items-center py-2 mb-3">
            <span class="fs-6 mb-0">Загальна сума по чекам:</span>
            <span class="fs-5 fw-bold mb-0">@ViewModel.TotalSum.ToString("C2")</span>
        </div>
    }
</div>

@if (ViewModel.Receipts == null)
{
    <p><em>Завантаження...</em></p>
}
else if (!ViewModel.Receipts.Any())
{
    <p><em>Немає чеків</em></p>
}
else
{
    <div class="receipt-list" style="max-height: 60vh; overflow-y: auto; padding-right: 10px;">
        @foreach (var receipt in ViewModel.FilteredReceipts)
        {
            <ReceiptView Receipt="receipt" OnDelete="ViewModel.DeleteReceipt"/>
        }
        
        @if (!ViewModel.FilteredReceipts.Any())
        {
            <div class="alert alert-info mt-2">Не знайдено чеків за вказаними фільтрами.</div>
        }
    </div>
}

@code {
    protected override void OnInitialized()
    {
        ViewModel.LoadReceipts();
    }
    
    private void ClearFilters()
    {
        ViewModel.ClearFilters();
        StateHasChanged();
    }
}
