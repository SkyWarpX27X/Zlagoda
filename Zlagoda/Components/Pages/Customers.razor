@page "/customers"
@rendermode InteractiveServer
@using Zlagoda.Components.ItemViews
@using Zlagoda.Components.ItemModifies
@using Zlagoda.ViewModels
@inject CustomersVM ViewModel

<h3>Постійні клієнти</h3>

<div class="mb-3">
    @if (ViewModel.IsCreating && ViewModel.NewCustomer != null)
    {
        <CustomerModify Customer="@ViewModel.NewCustomer" OnSave="@ViewModel.SaveNewCustomer" OnCancel="@ViewModel.CancelCreate" />
    }
    else
    {
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 mb-3">
            <button class="btn btn-success" @onclick="ViewModel.ShowCreateNew">Додати клієнта</button>
            <div class="d-flex align-items-end gap-3 flex-wrap">
                <div>
                    <label for="percentFilter" class="form-label fw-bold mb-1">Фільтрувати за відсотком:</label>
                    <input type="number" id="percentFilter" class="form-control" @bind="ViewModel.SearchPercent" @bind:after="StateHasChanged" placeholder="Введіть відсоток..." />
                </div>
            </div>
        </div>
    }
</div>

@if (ViewModel.Customers == null)
{
    <p><em>Завантаження...</em></p>
}
else if (!ViewModel.FilteredCustomers.Any())
{
    <p><em>Немає клієнтів за вказаними фільтрами</em></p>
}
else
{
    <div class="customer-list" style="max-height: 70vh; overflow-y: auto; padding-right: 10px;">
        @foreach (var customer in ViewModel.FilteredCustomers)
        {
            <CustomerView Customer="@customer" OnSave="ViewModel.EditCustomer" OnDelete="ViewModel.DeleteCustomer"/>
        }
    </div>
}

@code {
    
    protected override void OnInitialized()
    {
        ViewModel.LoadCustomers();
    }
}
